WRK:task{id:"T-002", status:"open", governor:"hermes", assignee:"heimdall", priority:"high", complexity:"complex", cycle:"CYCLE-02", created:"2026-07-11T13:31:03Z", updated:"2026-07-11T13:31:03Z"}

$2: OBJECTIVE

OBJ:objective{text:"Ejecutar auditoría ejecutable de ArqUX siguiendo protocolo ARQUX_EXECUTABLE_AUDIT_PROTOCOL.md y dejando resultado completo en docs/"}

$3: PROCEDURE

STP:step1{action:"Leer protocolo ARQUX_EXECUTABLE_AUDIT_PROTOCOL.md"}
STP:step2{action:"Ejecutar todos los pasos de auditoría definidos"}
STP:step3{action:"Recopilar evidencia usando handlers MCP y herramientas de Arqux"}
STP:step4{action:"Generar informe completo en formato Markdown"}
STP:step5{action:"Guardar informe en docs/ con nombre ARQUX_AUDIT_REPORT_<timestamp>.md"}
STP:step6{action:"Incluir todas las secciones de evidencia, resultados, verificaciones y conclusiones"}

$4: ACCEPTANCE

CLAIM:ac1{criterion:"Protocolo ejecutado completamente"}
CLAIM:ac2{criterion:"Informe generado y guardado en docs/"}
CLAIM:ac3{criterion:"Informe incluye todas las secciones requeridas por el protocolo"}
