$5: ACCEPTANCE

CLAIM:ac1{criterion:"AC-01: blueprint.complete llama a evidence.record() con kind=task_complete y detalle del BLP completado"}
CLAIM:ac2{criterion:"AC-02: blueprint.task llama a evidence.record() con kind=task_complete y task_id"}
CLAIM:ac3{criterion:"AC-03: blueprint.ac llama a evidence.record() con kind=note y resultado de la verificacion"}
CLAIM:ac4{criterion:"AC-04: blueprint.approve llama a evidence.record() con kind=decision"}
